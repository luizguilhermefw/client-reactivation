generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(uuid())
  name        String   // normalizado (busca)
  displayName String   // nome bonito
  cnpj        String   @unique
  users       User[]
  customers   Customer[]
  automations Automation[]
  createdAt   DateTime @default(now())

  @@index([name])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  createdAt DateTime @default(now())
}

model Customer {
  id               String   @id @default(uuid())
  name             String
  phone            String
  lastPurchaseDate DateTime
  company          Company  @relation(fields: [companyId], references: [id])
  companyId        String
  logs             MessageLog[]
  createdAt        DateTime @default(now())

  @@index([companyId])
  @@index([phone])
}

model Automation {
  id        String   @id @default(uuid())
  name      String
  daysAfter Int
  message   String
  isActive  Boolean  @default(true)
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  logs      MessageLog[]
  createdAt DateTime @default(now())

  @@index([companyId])
}

model MessageLog {
  id             String     @id @default(uuid())
  customer       Customer   @relation(fields: [customerId], references: [id])
  customerId     String
  automation     Automation @relation(fields: [automationId], references: [id])
  automationId   String
  scheduledDate  DateTime
  status         LogStatus
  createdAt      DateTime   @default(now())

  @@index([customerId])
  @@index([automationId])
}

enum LogStatus {
  PENDING
  SENT
  FAILED
}