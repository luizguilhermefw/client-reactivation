generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
}

model Company {
  id            String            @id @default(uuid())
  name          String
  displayName   String
  cnpj          String            @unique

  status        CompanyStatus     @default(PENDING)

  createdAt     DateTime          @default(now())
  approvedAt    DateTime?

  users         User[]
  customers     Customer[]
  automations   Automation[]

  @@index([name])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  createdAt DateTime @default(now())
  isAdmin   Boolean @default(false)
}

model Customer {
  id                    String       @id @default(uuid())
  name                  String
  phone                 String
  lastPurchaseDate      DateTime
  birthDate             DateTime?
  isActiveForAutomation Boolean      @default(true)
  company               Company      @relation(fields: [companyId], references: [id])
  companyId             String
  logs                  MessageLog[]
  createdAt             DateTime     @default(now())

  @@unique([id, companyId])
  @@index([companyId])
  @@index([phone])
}

model Automation {
  id   String         @id @default(uuid())
  name String
  type AutomationType @default(REACTIVATION)

  daysAfter Int
  message   String
  isActive  Boolean @default(true)

  cooldownHours Int @default(24)

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  logs      MessageLog[]
  createdAt DateTime     @default(now())

  @@unique([companyId, name])
  @@unique([id, companyId])
  @@index([companyId])
}

model MessageLog {
  id String @id @default(uuid())

  customerId   String
  automationId String

  status LogStatus

  scheduledDate DateTime
  sentAt        DateTime?

  createdAt DateTime @default(now())

  customer   Customer   @relation(fields: [customerId], references: [id])
  automation Automation @relation(fields: [automationId], references: [id])

  @@index([customerId, automationId])
  @@index([sentAt])
}

enum AutomationType {
  REACTIVATION
  BIRTHDAY
  CAMPAIGN
  MAINTENANCE
}

enum LogStatus {
  PENDING
  SENT
  FAILED
}
